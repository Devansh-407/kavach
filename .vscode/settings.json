{
  "css.validate": false,
  "scss.validate": false,
  "less.validate": false,
  "tailwindCSS.includeLanguages": {
    "css": "css",
    "scss": "scss",
    "less": "less"
  },
  "tailwindCSS.experimental.classRegex": [
    ["cva\\(([^)]*)\\)", "[\"'`]([^\"'`]*).*?[\"'`]"],
    ["cx\\(([^)]*)\\)", "(?:'|\"|`)([^']*)(?:'|\"|`)"]
  ],
  "editor.quickSuggestions": {
    "strings": true
  },
  "files.associations": {
    "*.css": "tailwindcss"
  },
  "css.customData": [".vscode/tailwind.json"],
  "tailwindCSS.validate": true,
  "tailwindCSS.lint.cssConflict": "warning",
  "tailwindCSS.lint.invalidScreen": "error",
  "tailwindCSS.lint.invalidVariant": "error",
  "tailwindCSS.lint.recommendedVariantOrder": "warning",
  "tailwindCSS.hovers": true,
  "tailwindCSS.suggestions": true,
  "tailwindCSS.codeActions": true,
  "css.lint.unknownAtRules": "ignore",
  "css.lint.validProperties": ["@tailwind", "@apply", "@layer", "@config", "@variants", "@responsive", "@keyframes"],
  "emmet.includeLanguages": {
    "javascript": "javascriptreact",
    "typescript": "typescriptreact"
  },
  "css.lint.unknownProperties": "ignore",
  "css.lint.ieHack": "ignore",
  "css.lint.duplicateProperties": "warning",
  "css.lint.emptyRules": "warning",
  "css.lint.importStatement": "ignore",
  "css.lint.boxModel": "ignore",
  "css.lint.universalSelector": "ignore",
  "css.lint.zeroUnits": "ignore",
  "css.lint.important": "ignore",
  "css.lint.arguments": "ignore",
  "css.lint.complexSelectors": "ignore",
  "css.lint.vendorPrefix": "ignore",
  "css.lint.idSelectors": "ignore",
  "css.lint.duplicateSelectors": "ignore",
  "css.lint.propertyIgnoredDueToDisplay": "ignore",
  "css.lint.qualifiedHeadings": "ignore",
  "css.lint.compatibleVendorPrefixes": "ignore",
  "css.lint.fontFaceProperties": "ignore",
  "css.lint.keyframeDeclarations": "ignore",
  "css.lint.shorthandProperties": "ignore",
  "css.lint.overqualifiedElements": "ignore",
  "css.lint.headingInHeading": "ignore",
  "css.lint.regexSelectors": "ignore",
  "css.lint.selectorAttributeOperator": "ignore",
  "css.lint.selectorAttributeOperatorDisallowed": "ignore",
  "css.lint.selectorAttributeOperatorSpace": "ignore",
  "css.lint.selectorAttributeQuotes": "ignore",
  "css.lint.selectorCombinator": "ignore",
  "css.lint.selectorCombinatorDisallowed": "ignore",
  "css.lint.selectorDescendantCombinatorNoSpace": "ignore",
  "css.lint.selectorPseudoClass": "ignore",
  "css.lint.selectorPseudoClassCapitalization": "ignore",
  "css.lint.selectorPseudoClassNot": "ignore",
  "css.lint.selectorPseudoClassParenthesesSpace": "ignore",
  "css.lint.selectorPseudoClassParenthesesSpaceInside": "ignore",
  "css.lint.selectorPseudoElement": "ignore",
  "css.lint.selectorPseudoElementColon": "ignore",
  "css.lint.selectorPseudoElementColonSpace": "ignore",
  "css.lint.selectorPseudoElementNot": "ignore",
  "css.lint.selectorPseudoElementNoColon": "ignore",
  "css.lint.selectorType": "ignore",
  "css.lint.selectorTypeNoIgnored": "ignore",
  "css.lint.selectorUniversal": "ignore"
}
